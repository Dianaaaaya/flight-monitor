# ── 数据源 ─────────────────────────────────────
# 数据源选择：serpapi | travelpayouts | kiwi | mock
#   mock          不需要任何 key，用假数据本地跑通流程
#   serpapi       Google Flights 真实时价（推荐）：注册 https://serpapi.com 拿 key，免费 100 次/月
#   travelpayouts 免费但为缓存价，可能有几小时延迟
#   kiwi          Kiwi Tequila，现仅对 affiliate 开放，个人一般注册不了
PROVIDER=mock

# SerpApi key —— 注册后在 https://serpapi.com/manage-api-key 查看
SERPAPI_KEY=your_serpapi_key_here

# Travelpayouts (Aviasales) token —— 备用免费源
TRAVELPAYOUTS_TOKEN=

# Kiwi Tequila API key（若你有 affiliate 权限才填）
KIWI_API_KEY=

# ── 通知渠道 ───────────────────────────────────
# telegram（默认，推荐）| email
NOTIFY_CHANNEL=telegram

# ── Telegram ───────────────────────────────────
# 1. Telegram 里找 @BotFather → /newbot → 拿到 token
# 2. 给你的 bot 发一句话，再跑 `python -m flight_monitor.telegram_setup` 拿 chat id
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── 邮件（备选，NOTIFY_CHANNEL=email 时才用；Gmail 需应用专用密码） ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL=cm7295@nyu.edu
